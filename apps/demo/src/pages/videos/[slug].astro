---
import { getCollection } from 'astro:content';
import Layout from '@/layouts/Layout.astro';

export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map((video) => ({
    params: { slug: video.id.replace('.md', '') },
    props: { video },
  }));
}

const { video } = Astro.props;
const data = video.data;

// 判断是否是未来视频
const now = new Date();
const publishDate = new Date(data.date);
const isFuture = publishDate > now;

// 数字格式化（K / M）
function formatNumber(num: number): string {
  if (num >= 1_000_000) return (num / 1_000_000).toFixed(1) + 'M';
  if (num >= 1000) return (num / 1000).toFixed(1) + 'K';
  return num.toLocaleString();
}

// 作者（默认 AxelEwan，支持联合创作）
const author = data.author || 'AxelEwan';
---

<Layout title={data.title}>
  <main class="min-h-screen bg-black text-white pb-20 dark:bg-zinc-950">
    <div class="max-w-7xl mx-auto px-6 pt-8">
      <!-- 视频播放器 -->
      <div class="aspect-video bg-zinc-950 rounded-3xl overflow-hidden mb-12 relative shadow-2xl">
        {isFuture ? (
          <div class="relative w-full h-full">
            <img src={data.cover} class="w-full h-full object-cover filter blur-xl" alt={data.title} />
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-black/70 backdrop-blur-md">
              <!-- Phosphor lock-bold -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 mb-6 text-white" fill="none" viewBox="0 0 256 256">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 176a48 48 0 1 0 0-96 48 48 0 0 0 0 96Z"/>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 224c-40-32-80-64-80-112a80 80 0 1 1 160 0c0 48-40 80-80 112Z"/>
              </svg>
              <div class="text-3xl font-bold mb-2">即将发布</div>
              <div id="countdown" class="text-4xl font-mono tabular-nums"></div>
            </div>
          </div>
        ) : (
          <div class="w-full h-full">
            {data.platforms?.bilibili ? (
              <iframe 
                src={`https://player.bilibili.com/player.html?bvid=${data.platforms.bilibili}&autoplay=0&muted=0`} 
                class="w-full h-full" 
                frameborder="0" 
                allowfullscreen
              ></iframe>
            ) : data.platforms?.youtube ? (
              <iframe 
                src={`https://www.youtube.com/embed/${data.platforms.youtube}`} 
                class="w-full h-full" 
                frameborder="0" 
                allowfullscreen
              ></iframe>
            ) : (
              <img src={data.cover} class="w-full h-full object-cover" alt={data.title} />
            )}
          </div>
        )}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- 左侧信息 -->
        <div class="lg:col-span-8">
          <h1 class="text-5xl font-bold tracking-tighter mb-4">{data.title}</h1>
          
          <!-- 标题下方：作者名称（带 user-bold 图标） -->
          <div class="flex items-center gap-2 text-zinc-400 mb-8">
            <!-- Phosphor user-bold -->
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 256 256">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 136a48 48 0 1 0 0-96 48 48 0 0 0 0 96Z"/>
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M200 216a72 72 0 0 0-144 0"/>
            </svg>
            <span class="text-white font-medium">{author}</span>
          </div>

          <!-- 三列区域：第一列改为发布日期，其余为播放量和点赞 -->
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12 border-t border-b border-zinc-800 py-8">
            <!-- 第一列：发布日期（calendar-bold） -->
            <div class="flex items-center gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 256 256">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M208 48H48a16 16 0 0 0-16 16v144a16 16 0 0 0 16 16h160a16 16 0 0 0 16-16V64a16 16 0 0 0-16-16Z"/>
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M176 24v24M80 24v24M40 88h176"/>
              </svg>
              <div>
                <div class="text-4xl font-bold text-white">{new Date(data.date).toLocaleDateString('zh-CN')}</div>
                <div class="text-sm text-zinc-400">发布日期</div>
              </div>
            </div>

            <!-- 播放量 -->
            <div class="flex items-center gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 256 256">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 56c-48 0-80 48-80 72s32 72 80 72 80-48 80-72-32-72-80-72Z"/>
                <circle cx="128" cy="128" r="24" stroke="currentColor" stroke-width="24"/>
              </svg>
              <div>
                <div class="text-4xl font-bold text-white">{formatNumber(data.views)}</div>
                <div class="text-sm text-zinc-400">播放量</div>
              </div>
            </div>

            <!-- 点赞 -->
            <div class="flex items-center gap-4">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 256 256">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 216l-12-11C68 164 32 124 32 80a48 48 0 0 1 96-12 48 48 0 0 1 96 12c0 44-36 84-84 125Z"/>
              </svg>
              <div>
                <div class="text-4xl font-bold text-white">{formatNumber(data.likes)}</div>
                <div class="text-sm text-zinc-400">点赞</div>
              </div>
            </div>
          </div>

          <p class="text-xl text-zinc-300 leading-relaxed mb-8">{data.intro}</p>

          <!-- Tag + 位置 -->
          <div class="flex flex-wrap gap-3 mb-10">
            {data.tags.map((tag: string) => (
              <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-zinc-900 text-sm rounded-3xl">
                <!-- tag-bold -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 256 256">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M200 48H56a8 8 0 0 0-8 8v152a8 8 0 0 0 8 8h144a8 8 0 0 0 8-8V56a8 8 0 0 0-8-8Z"/>
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M96 88a8 8 0 1 1-8-8 8 8 0 0 1 8 8Z"/>
                </svg>
                {tag}
              </span>
            ))}
            {data.location && (
              <span class="inline-flex items-center gap-1.5 px-4 py-1.5 text-zinc-400 text-sm">
                <!-- map-pin-bold -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 256 256">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 176a48 48 0 1 0 0-96 48 48 0 0 0 0 96Z"/>
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 224c-40-32-80-64-80-112a80 80 0 1 1 160 0c0 48-40 80-80 112Z"/>
                </svg>
                {data.location}
              </span>
            )}
          </div>

          <!-- 评论区 -->
          {data.enableComments && data.comments?.length > 0 && (
            <div>
              <h3 class="flex items-center gap-2 text-2xl font-semibold mb-6">
                <!-- chat-bold -->
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 256 256">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 216H56a16 16 0 0 1-16-16V88a16 16 0 0 1 16-16h144a16 16 0 0 1 16 16v64a16 16 0 0 1-16 16h-16Z"/>
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 216l-32-32H56a16 16 0 0 1-16-16V88a16 16 0 0 1 16-16h144a16 16 0 0 1 16 16v64a16 16 0 0 1-16 16h-16Z"/>
                </svg>
                观众评论
              </h3>
              <div class="space-y-8">
                {data.comments.map((comment: any, i: number) => (
                  <div class={`flex gap-4 ${i === data.comments.length - 1 ? 'opacity-30 blur-sm' : ''}`}>
                    <img src={comment.avatar} class="w-10 h-10 rounded-full flex-shrink-0" />
                    <div>
                      <div class="font-medium">{comment.nickname}</div>
                      <div class="text-zinc-300 mt-1">{comment.content}</div>
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-10 text-center">
                <a href={`https://www.bilibili.com/video/${data.platforms?.bilibili || ''}`} 
                   target="_blank" 
                   class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 transition-colors">
                  查看更多评论 →
                </a>
              </div>
            </div>
          )}
        </div>

        <!-- 右侧平台 -->
        <div class="lg:col-span-4">
          <div class="sticky top-8">
            <h4 class="text-lg text-zinc-400 mb-6">在其他平台观看</h4>
            <div class="flex flex-col gap-4">
              {data.platforms?.bilibili && (
                <a href={`https://www.bilibili.com/video/${data.platforms.bilibili}`} target="_blank" 
                   class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- 临时用 play-bold，可换成 bilibili SVG -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 256 256">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 56c-48 0-80 48-80 72s32 72 80 72 80-48 80-72-32-72-80-72Z"/>
                  </svg>
                  <div>
                    <div class="font-medium">Bilibili</div>
                    <div class="text-xs text-zinc-400">大陆首选</div>
                  </div>
                </a>
              )}
              {data.platforms?.youtube && (
                <a href={`https://www.youtube.com/watch?v=${data.platforms.youtube}`} target="_blank" 
                   class="flex items-center gap-4 p-5 bg-zinc-900 hover:bg-zinc-800 rounded-2xl transition-all">
                  <!-- Phosphor youtube-logo-bold 风格临时替代 -->
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 256 256">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="24" d="M128 56c-48 0-80 48-80 72s32 72 80 72 80-48 80-72-32-72-80-72Z"/>
                  </svg>
                  <div>
                    <div class="font-medium">YouTube</div>
                    <div class="text-xs text-zinc-400">国际版</div>
                  </div>
                </a>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- 未来视频倒计时脚本（不变） -->
  {isFuture && (
    <script define:vars={{ publishDate: publishDate.getTime() }}>
      const countdownEl = document.getElementById('countdown');
      const end = new Date({publishDate}).getTime();
      const timer = setInterval(() => {
        const diff = end - Date.now();
        if (diff < 0) { clearInterval(timer); window.location.reload(); return; }
        const h = Math.floor(diff / 3600000).toString().padStart(2, '0');
        const m = Math.floor((diff % 3600000) / 60000).toString().padStart(2, '0');
        const s = Math.floor((diff % 60000) / 1000).toString().padStart(2, '0');
        countdownEl.textContent = `${h} : ${m} : ${s}`;
      }, 1000);
    </script>
  )}
</Layout>
